---
import { siteConfig } from '../config/site';

interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="site-header">
	<div class="shell header-inner">
		<a class="brand" href="/">
			<span class="brand-mark">CB</span>
			<span>
				<strong>{siteConfig.title}</strong>
				<small>Single repository publishing</small>
			</span>
		</a>
		<nav class="header-nav" aria-label="Primary">
			{siteConfig.navigation.map((item) => {
				const isActive =
					item.href === '/'
						? currentPath === item.href
						: currentPath.startsWith(item.href.replace(/\/$/, ''));
				return (
					<a class:list={[{ active: isActive }]} href={item.href}>
						{item.label}
					</a>
				);
			})}
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: relative;
		z-index: 2;
		padding: 1.25rem 1.5rem 0;
	}

	.header-inner {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 1.15rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(10, 16, 30, 0.72);
		box-shadow: 0 18px 40px -28px rgba(0, 0, 0, 0.68);
		backdrop-filter: blur(16px);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		color: inherit;
		text-decoration: none;
	}

	.brand strong {
		display: block;
		font-size: 0.98rem;
	}

	.brand small {
		display: block;
		color: var(--muted);
		font-size: 0.8rem;
	}

	.brand-mark {
		display: grid;
		place-items: center;
		width: 2.55rem;
		height: 2.55rem;
		border-radius: 999px;
		background: rgba(97, 244, 222, 0.14);
		border: 1px solid rgba(97, 244, 222, 0.22);
		font-weight: 800;
	}

	.header-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}

	.header-nav a {
		padding: 0.55rem 0.85rem;
		border-radius: 999px;
		color: var(--muted);
		text-decoration: none;
		font-weight: 700;
		border: 1px solid transparent;
	}

	.header-nav a.active {
		background: rgba(97, 244, 222, 0.12);
		border-color: rgba(97, 244, 222, 0.22);
		color: #dffef6;
	}

	@media (max-width: 720px) {
		.site-header {
			padding: 1rem 1rem 0;
		}

		.header-inner {
			border-radius: 1.5rem;
		}
	}
</style>
