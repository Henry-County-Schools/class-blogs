---
interface RecentPost {
	title: string;
	description: string;
	date: string;
	studentName: string;
	studentSlug: string;
	postUrl: string;
	studentUrl: string;
	tags: string[];
}

interface ProposalData {
	title: string;
	description: string;
	routeExample: string;
	studentCount: number;
	postCount: number;
	recentPosts: RecentPost[];
	editPaths: string[];
	workflow: string[];
}

interface Props {
	data: ProposalData;
	secondaryHref?: string;
	secondaryLabel?: string;
	kicker?: string;
	titleLabel?: string;
	eyebrow?: string;
}

const {
	data,
	secondaryHref = '/rss.xml',
	secondaryLabel = 'RSS feed',
	kicker = 'A dark, broadcast-style concept that treats the course homepage like a control surface: subpaths are assigned, PRs are reviewed, and every approved post radiates from one deploy.',
	titleLabel = 'Class Blogs',
	eyebrow = 'Shared domain publishing',
} = Astro.props;
---

<a class="skip-link" href="#main">Skip to content</a>
<main id="main" class="page">
	<header class="header">
		<div>
			<p class="label">{eyebrow}</p>
			<p class="title">{titleLabel}</p>
		</div>
	</header>

	<section class="hero">
		<div class="hero-copy">
			<p class="label">Shared domain transmission</p>
			<h1>One publish pipeline for the whole class.</h1>
			<p class="lead">{kicker}</p>
			<div class="hero-links">
				<a href="/students/">Directory</a>
				<a href="/docs/">Student docs</a>
				<a href={secondaryHref}>{secondaryLabel}</a>
			</div>
		</div>
		<div class="hero-metrics">
			<div class="metric">
				<span>Route</span>
				<strong>{data.routeExample}</strong>
			</div>
			<div class="metric">
				<span>Blogs</span>
				<strong>{data.studentCount}</strong>
			</div>
			<div class="metric">
				<span>Posts</span>
				<strong>{data.postCount}</strong>
			</div>
		</div>
	</section>

	<section class="ticker" aria-label="Platform summary">
		<span>Astro content collections</span>
		<span>slug registry</span>
		<span>ownership validation</span>
		<span>instructor review</span>
		<span>static deploy</span>
	</section>

	<section class="grid">
		<article class="panel">
			<p class="label">Workflow</p>
			{data.workflow.map((step, index) => (
				<div class="step">
					<b>{String(index + 1).padStart(2, '0')}</b>
					<p>{step}</p>
				</div>
			))}
		</article>
		<article class="panel">
			<p class="label">Student edit surface</p>
			<ul>
				{data.editPaths.map((path) => (
					<li>{path}</li>
				))}
			</ul>
		</article>
		<article class="panel">
			<p class="label">Recent signals</p>
			{data.recentPosts.map((post) => (
				<a class="signal" href={post.postUrl}>
					<strong>{post.title}</strong>
					<span>{post.studentName} / {post.date}</span>
				</a>
			))}
		</article>
	</section>
</main>

<style>
	body {
		margin: 0;
		background:
			radial-gradient(circle at 20% 15%, rgba(40, 212, 255, 0.2), transparent 20%),
			radial-gradient(circle at 85% 20%, rgba(255, 81, 190, 0.17), transparent 18%),
			linear-gradient(180deg, #070913 0%, #0c1020 45%, #070913 100%);
		color: #f5f7ff;
		font-family: 'Space Grotesk', sans-serif;
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: 1rem;
		padding: 0.75rem 1rem;
		background: #61f4de;
		color: #08101f;
		transform: translateY(-180%);
		transition: transform 160ms ease;
		text-decoration: none;
	}

	.skip-link:focus {
		transform: translateY(0);
	}

	.page {
		max-width: 78rem;
		margin: 0 auto;
		padding: 1.4rem 1.2rem 4rem;
	}

	.header,
	.hero,
	.grid {
		position: relative;
	}

	.header {
		display: flex;
		justify-content: space-between;
		align-items: start;
		gap: 1rem;
	}

	.label,
	.metric span,
	.step b,
	.ticker span {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #89a3c9;
	}

	.title {
		margin: 0.35rem 0 0;
		font-size: 1.2rem;
		font-weight: 700;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
		gap: 1.2rem;
		padding: 2.2rem 0 1.5rem;
	}

	.hero-copy h1 {
		max-width: 8.2ch;
		margin: 0.8rem 0 1rem;
		font-size: clamp(4rem, 9vw, 7rem);
		line-height: 0.9;
		letter-spacing: -0.06em;
	}

	.lead {
		max-width: 37rem;
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.7;
		color: #c7d4f1;
	}

	.hero-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.4rem;
	}

	.hero-links a {
		padding: 0.8rem 1rem;
		border-radius: 999px;
		border: 1px solid rgba(117, 153, 255, 0.24);
		background: rgba(10, 16, 30, 0.62);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
		color: inherit;
		text-decoration: none;
	}

	.hero-metrics {
		display: grid;
		gap: 0.9rem;
	}

	.metric,
	.panel {
		padding: 1rem;
		border: 1px solid rgba(117, 153, 255, 0.24);
		border-radius: 1.25rem;
		background: rgba(9, 13, 24, 0.72);
		backdrop-filter: blur(18px);
		box-shadow: 0 0 40px rgba(16, 24, 48, 0.28);
	}

	.metric strong {
		display: block;
		margin-top: 0.5rem;
		font-size: clamp(1.5rem, 3vw, 2.5rem);
	}

	.ticker {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0.85rem 1rem;
		margin: 0.4rem 0 1.3rem;
		border-top: 1px solid rgba(117, 153, 255, 0.24);
		border-bottom: 1px solid rgba(117, 153, 255, 0.24);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.step {
		display: grid;
		grid-template-columns: 2.75rem 1fr;
		gap: 0.7rem;
		padding: 0.8rem 0;
		border-top: 1px solid rgba(117, 153, 255, 0.16);
	}

	.panel ul {
		display: grid;
		gap: 0.85rem;
		padding-left: 1.2rem;
		color: #d0dcf5;
	}

	.signal {
		display: grid;
		gap: 0.2rem;
		padding: 0.85rem 0;
		border-top: 1px solid rgba(117, 153, 255, 0.16);
		color: inherit;
		text-decoration: none;
	}

	.signal span {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.82rem;
		color: #89a3c9;
	}

	@media (max-width: 920px) {
		.hero,
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
