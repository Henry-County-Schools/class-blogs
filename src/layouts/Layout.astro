---
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/dm-mono/400.css';
import '@fontsource/dm-mono/500.css';
import '@fontsource/source-serif-4/400.css';
import '@fontsource/source-serif-4/600.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig } from '../config/site';

interface Props {
	title?: string;
	description?: string;
	accent?: string;
}

const { title, description = siteConfig.description, accent = siteConfig.defaultAccent } = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? siteConfig.siteUrl);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
	</head>
	<body style={`--page-accent: ${accent};`}>
		<a class="skip-link" href="#main-content">Skip to content</a>
		<div class="page-shell">
			<div class="page-glow page-glow-left"></div>
			<div class="page-glow page-glow-right"></div>
			<SiteHeader currentPath={Astro.url.pathname} />
			<main class="page-main" id="main-content">
				<slot />
			</main>
			<SiteFooter />
		</div>
	</body>
</html>

<style>
	:root {
		--paper: #070913;
		--paper-strong: #0d1324;
		--ink: #f5f7ff;
		--muted: #9bb6df;
		--line: rgba(117, 153, 255, 0.24);
		--shadow: rgba(4, 10, 22, 0.48);
		--display-font: 'Space Grotesk', 'Segoe UI', sans-serif;
		--body-font: 'Space Grotesk', 'Segoe UI', sans-serif;
		--serif-font: 'Source Serif 4', Georgia, serif;
		--mono-font: 'DM Mono', 'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
		--panel: rgba(9, 13, 24, 0.72);
		--panel-strong: rgba(10, 16, 30, 0.88);
		--card-shadow:
			0 20px 44px -24px rgba(0, 0, 0, 0.58),
			0 0 44px -32px rgba(97, 244, 222, 0.24);
	}

	html {
		background:
			radial-gradient(circle at 20% 15%, rgba(40, 212, 255, 0.2), transparent 18%),
			radial-gradient(circle at 84% 18%, rgba(255, 81, 190, 0.16), transparent 18%),
			linear-gradient(180deg, #070913 0%, #0c1020 45%, #070913 100%);
		color: var(--ink);
		font-family: var(--body-font);
		line-height: 1.6;
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-height: 100vh;
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}

	a:visited {
		color: inherit;
	}

	a:hover {
		color: #dffef6;
	}

	a:focus-visible {
		outline: 2px solid rgba(97, 244, 222, 0.78);
		outline-offset: 3px;
	}

	img {
		display: block;
		max-width: 100%;
	}

	.page-shell {
		position: relative;
		min-height: 100vh;
		overflow: hidden;
	}

	.page-shell::before {
		content: '';
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.08), transparent 28%),
			repeating-linear-gradient(
				90deg,
				rgba(255, 255, 255, 0.025),
				rgba(255, 255, 255, 0.025) 1px,
				transparent 1px,
				transparent 4px
			);
		opacity: 0.6;
		mix-blend-mode: screen;
		pointer-events: none;
	}

	.page-main {
		position: relative;
		z-index: 1;
		padding: 0 1.5rem 4rem;
	}

	.page-glow {
		position: absolute;
		width: 36rem;
		height: 36rem;
		border-radius: 999px;
		filter: blur(44px);
		opacity: 0.44;
		pointer-events: none;
	}

	.page-glow-left {
		top: -11rem;
		left: -13rem;
		background: color-mix(in srgb, var(--page-accent) 68%, transparent 32%);
	}

	.page-glow-right {
		top: 8rem;
		right: -10rem;
		background: rgba(255, 81, 190, 0.16);
	}

	:global(.shell) {
		max-width: 78rem;
		margin: 0 auto;
	}

	:global(.eyebrow) {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.45rem 0.8rem;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(10, 16, 30, 0.62);
		color: var(--muted);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	:global(.section-title) {
		margin: 0;
		font-family: var(--display-font);
		font-size: clamp(2.4rem, 5vw, 4.6rem);
		line-height: 0.96;
		letter-spacing: -0.05em;
	}

	:global(.section-copy) {
		max-width: 44rem;
		margin: 0;
		color: var(--muted);
		font-size: 1.06rem;
	}

	:global(.panel) {
		background: var(--panel);
		border: 1px solid var(--line);
		border-radius: 1.5rem;
		box-shadow: var(--card-shadow);
		backdrop-filter: blur(18px);
	}

	:global(.meta-row) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		align-items: center;
		color: var(--muted);
		font-size: 0.88rem;
	}

	:global(.pill) {
		display: inline-flex;
		align-items: center;
		padding: 0.28rem 0.65rem;
		border-radius: 999px;
		background: rgba(10, 16, 30, 0.86);
		border: 1px solid rgba(117, 153, 255, 0.18);
	}

	:global(.button-link) {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.9rem 1.15rem;
		border-radius: 999px;
		background: #61f4de;
		color: #08101f;
		text-decoration: none;
		font-weight: 700;
		box-shadow: 0 0 24px rgba(97, 244, 222, 0.18);
	}

	:global(.button-link.subtle) {
		background: rgba(10, 16, 30, 0.62);
		color: var(--ink);
		border: 1px solid var(--line);
		box-shadow: none;
	}

	:global(.prose) {
		font-family: var(--serif-font);
		font-size: 1.12rem;
		line-height: 1.8;
	}

	:global(.prose h2),
	:global(.prose h3) {
		font-family: var(--display-font);
		line-height: 1;
		letter-spacing: -0.04em;
	}

	:global(.prose p),
	:global(.prose li) {
		color: #d6dff3;
	}

	:global(.prose a) {
		color: #7deedc;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.16em;
	}

	:global(.prose pre) {
		padding: 1rem;
		border-radius: 1rem;
		background: rgba(5, 9, 19, 0.96);
		border: 1px solid rgba(117, 153, 255, 0.2);
		overflow-x: auto;
		color: #f7f4ed;
	}

	:global(.prose code) {
		font-family: var(--mono-font);
		font-size: 0.92em;
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: 1rem;
		z-index: 3;
		padding: 0.8rem 1rem;
		border-radius: 999px;
		background: #61f4de;
		color: #08101f;
		text-decoration: none;
		transform: translateY(-180%);
		transition: transform 160ms ease;
	}

	.skip-link:focus,
	.skip-link:focus-visible {
		transform: translateY(0);
	}

	@media (max-width: 720px) {
		.page-main {
			padding: 0 1rem 3rem;
		}
	}
</style>
