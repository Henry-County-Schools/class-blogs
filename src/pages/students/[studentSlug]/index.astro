---
import PostList from '../../../components/PostList.astro';
import Layout from '../../../layouts/Layout.astro';
import { getPostsByStudent, getPublishedStudents, getStudentAccent, getStudentUrl } from '../../../lib/content';

export async function getStaticPaths() {
	const students = await getPublishedStudents();
	return students.map((student) => ({
		params: { studentSlug: student.data.slug },
		props: { student },
	}));
}

const { student } = Astro.props;
const posts = await getPostsByStudent(student.data.slug);
const accent = getStudentAccent(student);
const profileLinks = student.data.links ?? [];
---

<Layout title={student.data.displayName} description={student.data.bio} accent={accent}>
	<section class="shell student-page" style={`--student-accent: ${accent};`}>
		<div class="profile panel">
			<div class="profile-heading">
				<span class="eyebrow">Student blog</span>
				<p class="slug">/{student.data.slug}</p>
			</div>
			<h1 class="section-title">{student.data.displayName}</h1>
			<p class="section-copy">{student.data.bio}</p>
			<div class="meta-row">
				<span class="pill">@{student.data.githubUsername}</span>
				<span class="pill">{posts.length} published posts</span>
				<a class="pill" href={getStudentUrl(student.data.slug)}>
					Canonical URL
				</a>
			</div>
			{profileLinks.length > 0 && (
				<ul class="link-list">
					{profileLinks.map((link) => (
						<li>
							<a href={link.url}>{link.label}</a>
						</li>
					))}
				</ul>
			)}
		</div>

		<section class="post-archive">
			<div class="archive-heading">
				<span class="eyebrow">Archive</span>
				<h2 class="section-title">Published posts</h2>
			</div>
			<PostList items={posts} emptyMessage="This student has not published any posts yet." />
		</section>
	</section>
</Layout>

<style>
	.student-page {
		display: grid;
		gap: 1.5rem;
		padding: 2rem 0 3rem;
	}

	.profile {
		padding: 1.6rem;
		background:
			linear-gradient(145deg, rgba(10, 16, 30, 0.92), rgba(7, 11, 22, 0.96)),
			color-mix(in srgb, var(--student-accent) 12%, transparent);
	}

	.profile-heading,
	.archive-heading {
		display: grid;
		gap: 0.75rem;
	}

	.slug {
		margin: 0;
		font-family: var(--mono-font);
		font-size: 0.9rem;
		color: color-mix(in srgb, var(--student-accent) 65%, white 35%);
	}

	.link-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		padding: 0;
		margin: 1rem 0 0;
		list-style: none;
	}

	.link-list a {
		color: #dffef6;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.15em;
	}

	.link-list a:visited {
		color: #dffef6;
	}

	.post-archive {
		display: grid;
		gap: 1rem;
	}
</style>
