---
import { render } from 'astro:content';
import PostMeta from '../../../components/PostMeta.astro';
import Layout from '../../../layouts/Layout.astro';
import {
	getPostSlug,
	getPublishedPostEntries,
	getPublishedStudentBySlug,
	getStudentAccent,
	getStudentSlugFromPost,
	getStudentUrl,
} from '../../../lib/content';

export async function getStaticPaths() {
	const posts = await getPublishedPostEntries();
	return posts.map((post) => ({
		params: {
			studentSlug: getStudentSlugFromPost(post),
			postSlug: getPostSlug(post),
		},
		props: { post },
	}));
}

const { post } = Astro.props;
const studentSlug = getStudentSlugFromPost(post);
const student = await getPublishedStudentBySlug(studentSlug);

if (!student) {
	throw new Error(`Missing published student entry for slug "${studentSlug}".`);
}

const accent = getStudentAccent(student);
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description} accent={accent}>
	<article class="shell post-page">
		<header class="post-hero">
			<div class="hero-copy panel">
				<span class="eyebrow">Student post</span>
				<h1>{post.data.title}</h1>
				<p>{post.data.description}</p>
			</div>
			<div class="hero-meta panel">
				<PostMeta
					publishDate={post.data.publishDate}
					updatedDate={post.data.updatedDate}
					tags={post.data.tags}
					studentLabel={student.data.displayName}
					studentUrl={getStudentUrl(studentSlug)}
				/>
				<a class="button-link subtle" href={getStudentUrl(studentSlug)}>
					Back to /students/{studentSlug}/
				</a>
			</div>
		</header>

		<div class="post-body panel">
			<div class="prose">
				<Content />
			</div>
		</div>
	</article>
</Layout>

<style>
	.post-page {
		display: grid;
		gap: 1.5rem;
		padding: 2rem 0 3rem;
	}

	.post-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) minmax(16rem, 0.8fr);
		gap: 1.25rem;
		align-items: start;
	}

	.hero-copy {
		display: grid;
		gap: 1rem;
		padding: 1.35rem;
	}

	.hero-copy h1 {
		margin: 0;
		font-family: var(--display-font);
		font-size: clamp(2.6rem, 5vw, 5rem);
		line-height: 0.94;
		letter-spacing: -0.05em;
	}

	.hero-copy p {
		margin: 0;
		max-width: 40rem;
		color: #d0dcf5;
		font-size: 1.08rem;
	}

	.hero-meta,
	.post-body {
		padding: 1.35rem;
	}

	.hero-meta {
		display: grid;
		gap: 1rem;
	}

	.post-body {
		background: rgba(10, 16, 30, 0.86);
	}

	@media (max-width: 880px) {
		.post-hero {
			grid-template-columns: 1fr;
		}
	}
</style>
